{
  "manifest_version": 3,
  "name": "Vibepad Capture",
  "version": "1.0",
  "description": "Send selected text to your Vibepad inbox from any webpage",
  "permissions": ["contextMenus", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
